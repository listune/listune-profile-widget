# =============================================
# Listune Profile Widget — Environment Config
# =============================================
# Copy this file to .env and fill in your values.
# =============================================

# --- Discord Application ---
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:3000/oauth/discord/callback
DISCORD_API_BASE_URL=https://discord.com/api/v10

# --- Listune API ---
# Base URL of your deployed Listune API project
LISTUNE_API_BASE_URL=https://your-listune-api.example.com
# Admin secret matching the ADMIN_SECRET in the Listune API .env
LISTUNE_API_SECRET=your_listune_api_admin_secret_here

# --- Widget Branding ---
WIDGET_BOT_AVATAR_URL=https://listune.app/android-chrome-512x512.png

# --- Storage ---
JSON_DB_PATH=./data/widget-store.json

# --- Server ---
PORT=
NODE_ENV=development

# --- Optional ---
# Set to 'true' to auto-refresh all linked users every 24h
AUTO_REFRESH_DAILY=false